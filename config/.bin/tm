#!/usr/bin/env bash
#

set -euo pipefail

# Nerd Font icons (matching tmux status line)
ICON_TMUX=$'\uebc8'
ICON_CLOUD=$'\uf4ac'
ICON_GITHUB=$'\uf408'

changeSession() {
  local change
  [[ -n "${TMUX:-""}" ]] && change="switch-client" || change="attach-session"
  tmux set-environment -g SSH_CONNECTION "${SSH_CONNECTION:-""}" 2>/dev/null
  tmux $change -t "$1"
}

createSessionIfNeeded() {
  local name=$1
  [[ -n "${2:-}" ]] && dir=$2 || dir=$(pwd)
  tmux list-sessions -F "#{session_name}" 2>/dev/null |
    grep -q -E "^${name}$" ||
    tmux new-session -d -c "${dir}" -s "${name}"
}

attachRemoteSession() {
  local host=$1 name=$2
  if [[ -n "${TMUX:-""}" ]]; then
    tmux detach-client -E "ssh ${host} -t \"zsh -lic \\\"tmux attach-session -t ${name}\\\"\""
  else
    ssh "$host" -t "zsh -lic \"tmux attach-session -t $name\""
  fi
}

listLocalSessions() {
  local current_session
  current_session=$(tmux display-message -p '#{session_name}' 2>/dev/null || true)

  tmux list-sessions -F '#{session_name}' 2>/dev/null |
    while IFS= read -r session; do
      local marker=" "
      if [[ "$session" == "$current_session" ]]; then
        marker="\e[1;38;5;208m*\e[m"
      fi
      printf "\e[0;32m${ICON_TMUX}\e[m ${marker} %s\tlocal\t%s\n" "$session" "$session"
    done
}

listRemoteSessions() {
  local hosts="${TM_REMOTE_HOSTS:-""}"
  [[ -z "$hosts" ]] && return 0

  local pids=()
  local tmpdir
  tmpdir=$(mktemp -d)

  IFS=',' read -ra host_list <<<"$hosts"
  for host in "${host_list[@]}"; do
    (
      ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" \
        'zsh -lic "tmux list-sessions -F \"#{session_name}\""' 2>/dev/null |
        while IFS= read -r session; do
          printf "\e[0;33m${ICON_CLOUD}\e[m   %s (%s)\t%s\t%s\n" "$session" "$host" "$host" "$session"
        done >"$tmpdir/$host"
    ) &
    pids+=($!)
  done

  for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  cat "$tmpdir"/* 2>/dev/null || true
  rm -rf "$tmpdir"
}

listRepos() {
  local existing_sessions ghq_root
  existing_sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
  ghq_root=$(ghq root)

  ghq list | while IFS= read -r repo; do
    local basename="${repo##*/}"
    if echo "$existing_sessions" | grep -q -E "^${basename}$"; then
      continue
    fi
    local display_name="${repo##github.com/}"
    printf "\e[0;34m${ICON_GITHUB}\e[m   %s\trepo\t%s\t%s\n" "$display_name" "$basename" "$ghq_root/$repo"
  done
}

buildList() {
  local remote_out
  remote_out=$(mktemp)
  listRemoteSessions >"$remote_out" &
  local remote_pid=$!

  local local_out
  local_out=$(
    listLocalSessions
    listRepos
  )
  [[ -n "$local_out" ]] && printf '%s\n' "$local_out"

  wait "$remote_pid" 2>/dev/null || true
  cat "$remote_out"
  rm -f "$remote_out"
}

previewGitLog() {
  local kind=$1 name=$2 full_path=${3:-}
  local dir=""

  case "$kind" in
  local)
    dir=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null) || return 0
    ;;
  repo)
    dir="$full_path"
    ;;
  *)
    echo "(remote session)"
    return 0
    ;;
  esac

  git -C "$dir" rev-parse --is-inside-work-tree &>/dev/null || {
    echo "(not a git repo)"
    return 0
  }

  local branch
  branch=$(git -C "$dir" symbolic-ref --short HEAD 2>/dev/null || git -C "$dir" rev-parse --short HEAD)
  printf "\e[1;36m%s\e[m\n\n" "$branch"

  git -C "$dir" log --first-parent --color=always --format='%C(yellow)%h %C(green)%cd%C(auto)%d%n  %C(reset)%s' --date=format:'%Y-%m-%d %H:%M' -n 30
}

selectAndDispatch() {
  local fzf_opts=(--delimiter=$'\t' --with-nth=1 --no-hscroll --no-multi --ansi --tmux 90% --color bg:#292c3c --preview "$0 __preview {2} {3} {4}" --preview-window right:60%)

  local selected
  selected=$(buildList | fzf "${fzf_opts[@]}") || true
  [[ -z "$selected" ]] && exit 0

  local kind name full_path host
  kind=$(echo "$selected" | awk -F'\t' '{print $2}' | xargs)
  name=$(echo "$selected" | awk -F'\t' '{print $3}' | xargs)
  full_path=$(echo "$selected" | awk -F'\t' '{print $4}' | xargs)

  case "$kind" in
  local)
    changeSession "$name"
    ;;
  repo)
    createSessionIfNeeded "$name" "$full_path"
    changeSession "$name"
    ;;
  *)
    # kind is a remote hostname
    attachRemoteSession "$kind" "$name"
    ;;
  esac
}

main() {
  if [[ "${1:-}" == "__preview" ]]; then
    shift
    previewGitLog "$@"
    exit 0
  fi

  if [ $# -eq 1 ]; then
    createSessionIfNeeded "$1"
    changeSession "$1"
    exit
  fi

  selectAndDispatch
}

main "$@"
